# Increase network timeouts so flaky connections don't abort installs.
# These are standard npm config keys that bun also respects.
fetch-retries = 5
fetch-retry-mintimeout = 20000
fetch-retry-maxtimeout = 120000
fetch-timeout = 600000

# Reject installs if optional dependencies are missing.
engine-strict = true

# Pin Prisma to v6 — do NOT let npm/bun auto-upgrade to v7.
# Prisma 7 removed `url`/`directUrl` from schema.prisma and breaks our build.
# This setting forces npm to install the exact version pinned in package.json.
save-exact = true
